{
    "name": "hydra/authorization",
    "description": "Authorization library for Hydra PHP framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hydra\\Authorization\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hydra\\Authorization\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../core", "options": { "symlink": true } },
        { "type": "path", "url": "../http", "options": { "symlink": true } },
        { "type": "path", "url": "../session", "options": { "symlink": true } },
        { "type": "path", "url": "../auth", "options": { "symlink": true } }
    ],
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "hydra/core": "*",
        "hydra/http": "*",
        "hydra/auth": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
